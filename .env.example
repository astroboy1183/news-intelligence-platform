# Copy to .env (gitignored) and replace EVERY CHANGE_ME with a real value.
# docker-compose deliberately has no fallback defaults — it'll refuse to start otherwise.

# Postgres (used by docker-compose AND backend)
POSTGRES_USER=nip
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=nip

# MinIO root credentials (docker-compose, only used if you re-enable MinIO)
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME
