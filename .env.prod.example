# Copy to .env on the VM (NEVER commit the real .env).
# The values here are the only ones you usually need to change.

# --- public hostname ---
# Used by Caddy for TLS + by CORS allowlist. Set this to the hostname your VM
# is reachable at. Examples:
#   newsintel.duckdns.org          (free DDNS)
#   api.yourdomain.com             (your own domain)
APP_HOSTNAME=change-me.example.com

# --- frontend origin ---
# Vercel preview URLs are PR-specific; production is the stable one. List both.
# Comma-separated. CORS will only accept these origins.
CORS_ORIGINS=https://news-intelligence.vercel.app,https://localhost:3000

# --- postgres ---
# Pick strong credentials — these aren't dev defaults.
POSTGRES_USER=nip
POSTGRES_PASSWORD=CHANGE_ME_TO_SOMETHING_LONG_AND_RANDOM
POSTGRES_DB=nip

# --- internal URLs (don't change unless you know why) ---
DATABASE_URL=postgresql+asyncpg://nip:CHANGE_ME_TO_SOMETHING_LONG_AND_RANDOM@postgres:5432/nip
REDIS_URL=redis://redis:6379/0

# --- environment marker ---
ENVIRONMENT=prod

# --- scheduler cadence ---
# Defaults inside flows/serve.py are 2/5/10/30 min. If you want lighter load,
# edit flows/serve.py and adjust the cron strings (e.g. */15 instead of */2).
